# ============================================================
# FundRAG Multi-Agent 环境变量配置模板
# 复制本文件为 .env，并填入真实密钥
# ============================================================

# OpenAI API Key
# 申请地址：https://platform.openai.com/api-keys
#OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DeepSeek API Key
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxx      # DeepSeek控制台获取
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Tavily Search API Key（实时新闻搜索）
# 免费申请：https://tavily.com（每月1000次免费）
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# 数据源选择（Module 2：Wind/Choice 商业数据源）
# ============================================================
# auto / wind / choice / akshare（默认 auto，优先商业源，降级到 akshare）
DATA_SOURCE=auto

# Wind 配置（DATA_SOURCE=wind 时必填，需要 Wind 量化终端授权）
# WIND_USERNAME=your_wind_username
# WIND_PASSWORD=your_wind_password

# Choice 配置（DATA_SOURCE=choice 时必填，需要东方财富企业账号）
# CHOICE_ACCOUNT=your_choice_account
# CHOICE_PASSWORD=your_choice_password
